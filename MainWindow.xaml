<Window x:Class="RadiumLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Radium Launcher" Height="600" Width="1000" 
        Background="#121212" WindowStartupLocation="CenterScreen"
        Icon="Radeon_8x.png"
        WindowStyle="None" AllowsTransparency="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="15"/>
    </WindowChrome.WindowChrome>

    <Border CornerRadius="15" Background="#121212" BorderBrush="#222" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="#1A1A1A">
                <StackPanel>
                    <Image Source="Radeon_8x.png" 
                           Width="130" 
                           HorizontalAlignment="Left" 
                           Margin="25,25,0,5" 
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <TextBlock Text="UNOFFICIAL LAUNCHER" 
                               Foreground="#32CD32" 
                               FontSize="10" 
                               FontWeight="Bold" 
                               Margin="28,0,0,30" 
                               Opacity="0.7"/>

                    <Button Name="btnScreen" Content="LAUNCH SCREEN MODE" Click="LaunchScreen_Click" 
                            Height="45" Margin="15,5" Background="#32CD32" Foreground="Black" 
                            FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Name="btnVR" Content="LAUNCH VR MODE" Click="LaunchVR_Click" 
                            Height="45" Margin="15,5" Background="#32CD32" Foreground="Black" 
                            FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Separator Margin="25,15" Background="#333"/>

                    <Button Name="btnKill" Content="KILL PROCESS" Click="KillProcess_Click" 
                            Height="35" Margin="15,5" Background="#FF4444" Foreground="White" 
                            FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="CHANGE DIRECTORY" Click="ChangeDir_Click" 
                            Height="30" Margin="15,5" Background="#444" Foreground="White" 
                            BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="JOIN DISCORD" Click="Discord_Click" 
                            Height="30" Margin="15,5" Background="#5865F2" Foreground="White" 
                            BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <TextBlock Text="v1.0.0 Alpha" VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                           Foreground="#555" Margin="0,0,0,15" FontSize="10"/>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button Content="—" Click="Minimize_Click" Background="Transparent" Foreground="White" 
                            BorderThickness="0" Width="40" Height="40" FontSize="16"
                            WindowChrome.IsHitTestVisibleInChrome="True" Cursor="Hand"/>
                    <Button Content="✕" Click="Close_Click" Background="Transparent" Foreground="White" 
                            BorderThickness="0" Width="40" Height="40" FontSize="16"
                            WindowChrome.IsHitTestVisibleInChrome="True" Cursor="Hand"/>
                </StackPanel>

                <wv2:WebView2 Name="webView" Source="https://www.radie.app" Grid.Row="1" Margin="5"/>
            </Grid>
        </Grid>
    </Border>
</Window>